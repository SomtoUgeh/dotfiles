{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "plan-agent",
        "planningAgents": ["plan"],
      },
    ],
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "posthog": {
      "type": "remote",
      "url": "https://mcp-eu.posthog.com/mcp",
      "enabled": false,
    },
    "agentation": {
      "type": "local",
      "command": ["npx", "-y", "agentation-mcp", "server"],
      "enabled": true,
    },
    "shadcn": {
      "type": "local",
      "command": ["npx", "-y", "shadcn@latest", "mcp"],
      "enabled": true,
    },
    "paper": {
      "type": "remote",
      "url": "http://127.0.0.1:29979/mcp",
      "enabled": false,
    },
  },
  "permission": {
    "*": "allow",
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "question": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "task": {
      "*": "allow",
    },
    "external_directory": "allow",
    "doom_loop": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
  },
  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "*": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "question": "allow",
        "skill": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "task": {
          "*": "allow",
        },
        "external_directory": "allow",
        "doom_loop": "allow",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow",
        },
      },
    },
    "plan": {
      "mode": "primary",
      "permission": {
        "*": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "question": "allow",
        "skill": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "task": {
          "*": "allow",
        },
        "external_directory": "allow",
        "doom_loop": "allow",
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny",
          "*.env.example": "allow",
        },
      },
    },
  },
}
