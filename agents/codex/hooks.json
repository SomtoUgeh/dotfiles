{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${HOME}/code/dotfiles/agents/shared/hooks/git_guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/code/dotfiles/agents/skills/shaping/shaping-ripple.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.local/bin/plannotator\"",
            "timeout": 345600
          }
        ]
      }
    ]
  }
}
