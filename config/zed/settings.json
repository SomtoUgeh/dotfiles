// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Note: Context servers with API keys should be configured in
  // ~/.config/zed/settings.json.local (not tracked in dotfiles)
  "agent_servers": {
    "codex-acp": {
      "favorite_config_option_values": {
        "model": ["gpt-5.5"],
      },
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "buffer_font_family": ".ZedMono",
  "buffer_font_size": 13.0,
  "buffer_font_weight": 350.0,
  "ui_font_family": ".ZedMono",
  "ui_font_size": 15.0,
  "ui_font_weight": 350.0,
  "colorize_brackets": true,
  "git_panel": {
    "dock": "left",
    "tree_view": true,
    "sort_by_path": true,
  },
  "icon_theme": "Catppuccin Mocha",
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "inlay_hints": {
    "enabled": false,
  },
  "terminal": {
    "dock": "bottom",
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "language_models": {
    "opencode": {
      "show_zen_models": true,
      "show_go_models": true,
    },
  },
  "agent": {
    "default_model": {
      "provider": "openai",
      "model": "gpt-5.5",
    },
    "inline_assistant_model": {
      "provider": "openai",
      "model": "gpt-5.5",
    },
    "commit_message_model": {
      "provider": "openai",
      "model": "gpt-5.5",
    },
    "play_sound_when_agent_done": "when_hidden",
    "default_width": 600.0,
    "dock": "left",
  },
  "project_panel": {
    "entry_spacing": "comfortable",
    "default_width": 250.0,
    "dock": "right",
  },
  "pane_split_direction_vertical": "right",
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": true,
  },
  "use_smartcase_search": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "agent_ui_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Syntax",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "inlayHints": {
            "callArgumentNames": false,
          },
        },
      },
    },
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff", "!ty", "..."],
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
    },
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "context_servers": {},
  // Extensions Zed auto-installs on launch, so themes/icons carry over to a
  // fresh machine. "Ayu Light" (light theme) is built into Zed; the dark theme
  // "Syntax" and the "Catppuccin Mocha" icon theme are provided by extensions.
  "auto_install_extensions": {
    "html": true,
    "syntax": true,
    "catppuccin-icons": true,
  },
}
