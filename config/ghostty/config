# cmux terminal (Ghostty-backed) configuration
# cmux's embedded terminal reads ~/.config/ghostty/config.
# https://ghostty.org/docs/config

# Font
font-family = JetBrainsMono NFM
font-size = 16

# Spacing: extra line height (cell) + window padding for breathing room
adjust-cell-height = 12%
window-padding-x = 10
window-padding-y = 8

# Behavior
copy-on-select = clipboard
shell-integration = zsh

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = super+k=clear_screen
